<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Optimize>true</Optimize>
    <!-- Silence localization and entry point warnings for benchmark -->
    <NoWarn>$(NoWarn);CA1303;CS7022</NoWarn>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Nalix.SDK\Nalix.SDK.csproj" />
    <ProjectReference Include="..\..\src\Nalix.Network\Nalix.Network.csproj" />
    <ProjectReference Include="..\..\src\Nalix.Framework\Nalix.Framework.csproj" />
    <ProjectReference Include="..\..\src\Nalix.Common\Nalix.Common.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.0-preview.1.25080.5" />
  </ItemGroup>

</Project>
