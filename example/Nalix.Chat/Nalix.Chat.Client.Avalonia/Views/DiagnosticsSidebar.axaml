<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Nalix.Chat.Client.Avalonia.Views.DiagnosticsSidebar">

  <Border CornerRadius="12" BorderBrush="#2F4F6E" BorderThickness="1" Background="#17324C" Padding="12">
    <StackPanel Spacing="10">
      <TextBlock Text="Diagnostics" FontSize="18" FontWeight="SemiBold" Foreground="#F2F8FF" />

      <Border Background="#10253A" CornerRadius="8" Padding="10">
        <StackPanel Spacing="6">
          <TextBlock Text="RTT" Foreground="#A8C5E4" />
          <TextBlock Text="{Binding LatencyText}" FontSize="16" FontWeight="SemiBold" Foreground="#ECF6FF" />
        </StackPanel>
      </Border>

      <Border Background="#10253A" CornerRadius="8" Padding="10">
        <StackPanel Spacing="6">
          <TextBlock Text="Clock Drift" Foreground="#A8C5E4" />
          <TextBlock Text="{Binding DriftText}" FontSize="16" FontWeight="SemiBold" Foreground="#ECF6FF" />
        </StackPanel>
      </Border>

      <Border Background="#10253A" CornerRadius="8" Padding="10">
        <StackPanel Spacing="4">
          <TextBlock Text="Active Cipher" Foreground="#A8C5E4" />
          <TextBlock Text="{Binding ActiveCipher}" Foreground="#ECF6FF" />
          <TextBlock Text="{Binding RotationCounterText}" Foreground="#CADFF5" />
        </StackPanel>
      </Border>

      <Border Background="#10253A" CornerRadius="8" Padding="10">
        <StackPanel Spacing="4">
          <TextBlock Text="Session" Foreground="#A8C5E4" />
          <TextBlock Text="{Binding SessionIdentifier}" TextWrapping="Wrap" Foreground="#ECF6FF" />
          <TextBlock Text="{Binding ConnectionStateText}" Foreground="#CADFF5" />
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
