<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Nalix.Chat.Client.Avalonia.Views.ChatRoomView">

  <Border CornerRadius="12" BorderBrush="#2F4F6E" BorderThickness="1" Background="#132C45" Padding="12">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
      <TextBlock Text="{Binding HeaderTitle}" FontSize="18" FontWeight="SemiBold" Foreground="#F2F8FF" />

      <Border Grid.Row="1" CornerRadius="8" Background="#0F2134" Padding="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Messages}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8" Padding="10" CornerRadius="8" Background="#1A3551">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding SenderDisplayName}" FontWeight="SemiBold" Foreground="#EAF4FF" />
                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#D8E8FA" />
                    <TextBlock Text="{Binding TimestampText}" HorizontalAlignment="Right" Foreground="#88A9C8" FontSize="11" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <TextBox Text="{Binding DraftMessage, Mode=TwoWay}" Watermark="Write a message" />
        <Button Grid.Column="1" Content="Send" Command="{Binding SendMessageCommand}" MinWidth="90" />
      </Grid>
    </Grid>
  </Border>
</UserControl>
