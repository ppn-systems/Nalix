<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Nalix.Chat.Client.Avalonia.App">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#0D1B2A" Offset="0.0" />
          <GradientStop Color="#1B263B" Offset="0.55" />
          <GradientStop Color="#102A43" Offset="1.0" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="FontFamily" Value="Montserrat, Segoe UI, Arial" />
    </Style>
  </Application.Styles>
</Application>
