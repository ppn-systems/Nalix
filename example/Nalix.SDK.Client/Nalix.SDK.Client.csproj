<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<Nullable>enable</Nullable>
		<OutputType>Exe</OutputType>
		<ImplicitUsings>enable</ImplicitUsings>
		<TargetFramework>net10.0</TargetFramework>
		<ServerGarbageCollection>false</ServerGarbageCollection>
		<RuntimeIdentifiers>linux-x64;win-x64</RuntimeIdentifiers>
		<ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>

		<Optimize>true</Optimize>
		<TieredCompilation>true</TieredCompilation>
		<AssemblyName>Nalix.SDK.Client</AssemblyName>
		<RootNamespace>Nalix.SDK.Client</RootNamespace>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\src\Nalix.SDK\Nalix.SDK.csproj" />
		<ProjectReference Include="..\..\src\Nalix.Logging\Nalix.Logging.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Spectre.Console" Version="0.49.1" />
	</ItemGroup>

</Project>
