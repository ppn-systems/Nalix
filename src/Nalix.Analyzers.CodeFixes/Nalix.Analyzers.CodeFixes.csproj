<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<LangVersion>latest</LangVersion>
		<Nullable>enable</Nullable>
		<IsPackable>true</IsPackable>
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<AssemblyName>Nalix.Analyzers.CodeFixes</AssemblyName>
		<Description>Roslyn code fixes for Nalix analyzers.</Description>
		<OutputPath>..\..\build\bin\$(Configuration)\</OutputPath>
		<IntermediateOutputPath>..\..\build\obj\$(Configuration)\Nalix.Analyzers.CodeFixes\</IntermediateOutputPath>
		<NoWarn>$(NoWarn);CS1591</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\Nalix.Analyzers\Nalix.Analyzers.csproj" />
	</ItemGroup>

  <ItemGroup>
	  <PackageReference Include="System.Composition.Runtime" Version="9.0.0" PrivateAssets="all" />
	  <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.11.0" PrivateAssets="all" />
	  <PackageReference Include="System.Composition.AttributedModel" Version="9.0.0" PrivateAssets="all" />
	  <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.14.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
