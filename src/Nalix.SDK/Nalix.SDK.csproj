<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>

		<Nullable>enable</Nullable>
		<IsPackable>true</IsPackable>
		<IsTrimmable>false</IsTrimmable>
		<OutputType>Library</OutputType>

		<!-- NativeAOT: export UnmanagedCallersOnly symbols as a real DLL/.so/.dylib -->
		<Optimize>true</Optimize>
		<TrimMode>partial</TrimMode>
		<PublishAot>true</PublishAot>
		<StripSymbols>true</StripSymbols>
		<Deterministic>true</Deterministic>
		<IsAotCompatible>true</IsAotCompatible>
		<InvariantGlobalization>true</InvariantGlobalization>

		<!-- Reduce reflection metadata; keep it small & fast for interop -->
		<IlcOptimizationPreference>Speed</IlcOptimizationPreference>
		<IlcGenerateCompleteTypeMetadata>false</IlcGenerateCompleteTypeMetadata>

		<Description><![CDATA[
Nalix.SDK provides the client-side development kit for the Nalix ecosystem, offering high-level APIs, controller abstractions, time synchronization helpers, and localization (L10N) utilities for building distributed applications.

It acts as the bridge between application logic and the Nalix.Network layer, simplifying remote communication, configuration, and message orchestration through clean, extensible, and developer-friendly interfaces.
		]]></Description>

		<PackageReleaseNotes><![CDATA[
- Managed Sessions: Professional lifecycle management for TcpSession and UdpSession with automatic reconnection and state handling.
- Request-Response Pattern: High-level RequestAsync<TResponse> API featuring correlated packet matching and granular timeout management.
- Session Orchestration: Advanced extensions for handshakes, session resumption, and dynamic cipher rotation on active transport streams.
- Typed Messaging: Type-safe packet subscription model (On<T>) for clean and efficient application-level message handling.
- Resource Optimization: Full integration with the zero-allocation PacketRegistry for high-performance, pool-aware data processing.
		]]></PackageReleaseNotes>

		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>

	</PropertyGroup>

	<Import Project="..\Nalix.Build.props" />
	<Import Project="..\Package.Build.props" />

	<ItemGroup>
		<ProjectReference Include="..\Nalix.Codec\Nalix.Codec.csproj" />
		<ProjectReference Include="..\Nalix.Environment\Nalix.Environment.csproj" />
		<ProjectReference Include="..\Nalix.Abstractions\Nalix.Abstractions.csproj" />
	</ItemGroup>

	<ItemGroup Condition="'$(Configuration)' == 'Release'">
		<None Include="$(MSBuildProjectDirectory)\..\..\build\bin\$(Configuration)\Nalix.Analyzers.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Condition="Exists('$(MSBuildProjectDirectory)\..\..\build\bin\$(Configuration)\Nalix.Analyzers.dll')" />

		<None Include="$(MSBuildProjectDirectory)\..\..\build\bin\$(Configuration)\Nalix.Analyzers.CodeFixes.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Condition="Exists('$(MSBuildProjectDirectory)\..\..\build\bin\$(Configuration)\Nalix.Analyzers.CodeFixes.dll')" />
	</ItemGroup>
</Project>
