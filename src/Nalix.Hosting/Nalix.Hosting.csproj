<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>

		<Nullable>enable</Nullable>
		<IsPackable>true</IsPackable>
		<OutputType>Library</OutputType>
		<IsTrimmable>false</IsTrimmable>
		<Deterministic>true</Deterministic>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>
	
	<PropertyGroup>

		<Description><![CDATA[
Nalix.Hosting provides Microsoft-style host and builder APIs for the Nalix ecosystem. It wires configuration loading, diagnostic event bridging, packet dispatch, and TCP/UDP listener lifecycle into a familiar builder/build/start workflow for quickly bootstrapping Nalix-based servers.
		]]></Description>

		<PackageReleaseNotes><![CDATA[
- Unified Server Bootstrapping: Simplified Microsoft-style host builder APIs for seamless TCP and UDP transport orchestration.
- Diagnostic Event Bridge: Automatic bridging of DiagnosticListener events from Nalix.Environment and Nalix.Framework into ILogger with configurable minimum log level.
- Pluggable Security Hooks: Added support for custom UDP authentication predicates and security filtering directly during the build phase.
- Coordinated Lifecycle: Advanced management of configuration reloads, dispatch activation, and listener startup for robust service availability.
- Dependency-Injection Integration: Streamlined registration of core network services into the standard Nalix InstanceManager.
		]]></PackageReleaseNotes>
		
	</PropertyGroup>

	<Import Project="..\Nalix.Build.props" />
	<Import Project="..\Package.Build.props" />

	<ItemGroup>
		<ProjectReference Include="..\Nalix.Codec\Nalix.Codec.csproj" />
		<ProjectReference Include="..\Nalix.Network\Nalix.Network.csproj" />
		<ProjectReference Include="..\Nalix.Runtime\Nalix.Runtime.csproj" />
		<ProjectReference Include="..\Nalix.Framework\Nalix.Framework.csproj" />
		<ProjectReference Include="..\Nalix.Abstractions\Nalix.Abstractions.csproj" />
	</ItemGroup>

	<ItemGroup Condition="'$(Configuration)' == 'Debug'">
		<InternalsVisibleTo Include="Nalix.Network.Tests" />
		<InternalsVisibleTo Include="Nalix.Network.Benchmarks" />
	</ItemGroup>

	<ItemGroup Condition="'$(Configuration)' == 'Release'">
		<None Include="$(MSBuildProjectDirectory)\..\..\build\bin\$(Configuration)\Nalix.Analyzers.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Condition="Exists('$(MSBuildProjectDirectory)\..\..\build\bin\$(Configuration)\Nalix.Analyzers.dll')" />

		<None Include="$(MSBuildProjectDirectory)\..\..\build\bin\$(Configuration)\Nalix.Analyzers.CodeFixes.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Condition="Exists('$(MSBuildProjectDirectory)\..\..\build\bin\$(Configuration)\Nalix.Analyzers.CodeFixes.dll')" />
	</ItemGroup>

	<ItemGroup>
	  <Compile Update="Resource.Designer.cs">
	    <DesignTime>True</DesignTime>
	    <AutoGen>True</AutoGen>
	    <DependentUpon>Resource.resx</DependentUpon>
	  </Compile>
	</ItemGroup>

	<ItemGroup>
	  <EmbeddedResource Update="Resource.resx">
	    <Generator>ResXFileCodeGenerator</Generator>
	    <LastGenOutput>Resource.Designer.cs</LastGenOutput>
	  </EmbeddedResource>
	</ItemGroup>
</Project>
