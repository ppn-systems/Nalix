<Window x:Class="Nalix.SDK.Tools.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Nalix.SDK.Tools.Views"
        Title="{Binding Source={StaticResource ToolTexts}, Path=AppWindowTitle}"
        Width="1280"
        Height="720"
        MinWidth="1280"
        MaxWidth="1280"
        MinHeight="720"
        MaxHeight="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid>
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Padding="18,14"
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderStrongBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="{Binding Source={StaticResource ToolTexts}, Path=AppHeaderTitle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="{Binding Source={StaticResource ToolTexts}, Path=AppHeaderSubtitle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,6">
                            <TextBlock Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Text="{Binding Source={StaticResource ToolTexts}, Path=ThemeLabel}" />
                            <ComboBox Width="120"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedThemeOption}"
                                      DisplayMemberPath="DisplayName" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Top"
                    Margin="16,0,16,8"
                    Padding="12,8"
                    Background="{DynamicResource HeaderCardBrush}"
                    BorderBrush="{DynamicResource AccentSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <TextBlock Foreground="{DynamicResource InverseSecondaryTextBrush}"
                           Text="{Binding StatusText}" />
            </Border>

            <StatusBar DockPanel.Dock="Bottom" Padding="8,4" Background="{DynamicResource StatusBarBackgroundBrush}">
                <StatusBarItem Content="{Binding PacketBuilder.CurrentPacketSummary}" />
                <Separator />
                <StatusBarItem HorizontalAlignment="Right" Content="{Binding PacketBuilder.LastPingText}" />
            </StatusBar>

            <TabControl Margin="16">
                <TabItem Header="{Binding Source={StaticResource ToolTexts}, Path=TabPacketBuilder}">
                    <views:PacketBuilderView DataContext="{Binding PacketBuilder}" />
                </TabItem>
                <TabItem Header="{Binding Source={StaticResource ToolTexts}, Path=TabSendHistory}">
                    <views:PacketHistoryTabView DataContext="{Binding SentHistory}" />
                </TabItem>
                <TabItem Header="{Binding Source={StaticResource ToolTexts}, Path=TabReceiveHistory}">
                    <views:PacketHistoryTabView DataContext="{Binding ReceiveHistory}" />
                </TabItem>
                <TabItem Header="{Binding Source={StaticResource ToolTexts}, Path=TabPacketRegistryBrowser}">
                    <views:PacketRegistryBrowserView DataContext="{Binding PacketRegistryBrowser}" />
                </TabItem>
                <TabItem Header="{Binding Source={StaticResource ToolTexts}, Path=TabLog}">
                    <views:LogTabView DataContext="{Binding Log}" />
                </TabItem>
            </TabControl>
        </DockPanel>

        <views:HexViewerOverlay DataContext="{Binding HexViewer}" />
    </Grid>
</Window>
