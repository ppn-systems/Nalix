<Window x:Class="Nalix.SDK.Tools.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Nalix.SDK.Tools.Controls"
        xmlns:models="clr-namespace:Nalix.SDK.Tools.Models"
        Title="Nalix TCP Packet Testing Tool"
        Width="1280"
        Height="720"
        MinWidth="1280"
        MaxWidth="1280"
        MinHeight="720"
        MaxHeight="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB">
    <Window.Resources>
        <SolidColorBrush x:Key="RegistryTreeForegroundBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="RegistryTreeTypeBrush" Color="#64748B" />
        <SolidColorBrush x:Key="RegistryTreeSelectedBrush" Color="#1E40AF" />
        <SolidColorBrush x:Key="RegistryTreeSelectedForegroundBrush" Color="#F8FAFC" />
        <Style x:Key="RegistryTreePrimaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource RegistryTreeForegroundBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource RegistryTreeSelectedForegroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RegistryTreeTypeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource RegistryTreePrimaryTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource RegistryTreeTypeBrush}" />
        </Style>
        <HierarchicalDataTemplate DataType="{x:Type models:PacketPropertyDefinition}"
                                  ItemsSource="{Binding Children}">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="RegistryPropertyColumn" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="RegistryTypeColumn" />
                </Grid.ColumnDefinitions>
                <TextBlock FontWeight="SemiBold"
                           Style="{StaticResource RegistryTreePrimaryTextStyle}"
                           Text="{Binding DisplayName}"
                           MinWidth="180" />
                <TextBlock Grid.Column="1"
                           Margin="20,0,0,0"
                           Style="{StaticResource RegistryTreeTypeTextStyle}"
                           Text="{Binding PropertyType.Name}"
                           TextWrapping="NoWrap"
                           MinWidth="150" />
            </Grid>
        </HierarchicalDataTemplate>

        <Style x:Key="RegistryTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource RegistryTreeForegroundBrush}" />
            <Setter Property="Padding" Value="3,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RegistryTreeSelectedBrush}" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True" />
                        <Condition Property="IsSelectionActive" Value="False" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource RegistryTreeSelectedBrush}" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <DockPanel>
        <Border DockPanel.Dock="Top" Padding="18,14" Background="#0F172A">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Text="TCP Packet Testing Tool" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#94A3B8"
                               Text="Reflection-driven packet builder for Nalix FrameBase packets" />
                </StackPanel>

                <Border Grid.Column="1" Padding="12,8" Background="#1E293B" CornerRadius="8">
                    <TextBlock Foreground="#E2E8F0" Text="{Binding StatusText}" />
                </Border>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Padding="8,4" Background="#E2E8F0">
            <StatusBarItem Content="{Binding CurrentPacketSummary}" />
        </StatusBar>

        <TabControl Margin="16">
            <TabItem Header="Packet Builder">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="370" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <GroupBox Header="Connection" Margin="0,0,0,12">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="75" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Host" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Port" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,0,12" Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}" />

                                    <UniformGrid Grid.Row="2" Grid.ColumnSpan="2" Columns="2">
                                        <Button Margin="0,0,8,0" Command="{Binding ConnectCommand}" Content="Connect" />
                                        <Button Command="{Binding DisconnectCommand}" Content="Disconnect" />
                                    </UniformGrid>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Packet Selection" Margin="0,0,0,12">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Type" />
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              Margin="8,0,0,8"
                                              DisplayMemberPath="Name"
                                              ItemsSource="{Binding PacketTypes}"
                                              SelectionChanged="BuilderPacketTypeComboBox_SelectionChanged"
                                              SelectedItem="{Binding SelectedPacketType}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap"
                                               Text="Packet type is selected explicitly by MagicNumber identity." />
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Actions" Margin="0,0,0,12">
                                <UniformGrid Margin="10" Columns="3">
                                    <Button Margin="0,0,8,0" Command="{Binding ResetPacketCommand}" Content="Reset" />
                                    <Button Margin="0,0,8,0" Command="{Binding SerializePacketCommand}" Content="Serialize" />
                                    <Button Command="{Binding SendPacketCommand}" Content="Send" />
                                </UniformGrid>
                            </GroupBox>

                            <GroupBox Header="Builder Notes">
                                <TextBlock Margin="10" TextWrapping="Wrap" Foreground="#334155" Text="{Binding ResolutionText}" />
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Column="2" Padding="16" Background="White" CornerRadius="10" BorderBrush="#D9E2EC" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding CurrentPacketTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="#64748B" TextWrapping="Wrap" Text="{Binding CurrentPacketSummary}" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <controls:DynamicPropertyForm ItemsSource="{Binding CurrentProperties}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Send History">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Sent Packets">
                        <DockPanel Margin="10">
                            <Button DockPanel.Dock="Bottom"
                                    Margin="0,10,0,0"
                                    Command="{Binding ReopenSelectedSentPacketCommand}"
                                    Content="Reopen Selected Packet" />
                            <ListBox x:Name="SentHistoryListBox"
                                     DisplayMemberPath="Summary"
                                     ItemsSource="{Binding SentHistory}"
                                     MouseDoubleClick="SentHistoryListBox_MouseDoubleClick"
                                     SelectedItem="{Binding SelectedSentHistoryEntry}" />
                        </DockPanel>
                    </GroupBox>

                    <Border Grid.Column="2"
                            Padding="16"
                            Background="White"
                            CornerRadius="10"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SentDetail.Title}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap"
                                           Text="{Binding SentDetail.Summary}" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <controls:DynamicPropertyForm ItemsSource="{Binding SentDetail.Properties}" />
                            </ScrollViewer>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="16,0,0,0">
                                <Button Width="100"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Left"
                                        Command="{Binding SentDetail.CopyHexCommand}"
                                        Content="Copy Hex" />
                                <TextBox Padding="10"
                                         VerticalAlignment="Stretch"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         IsReadOnly="True"
                                         Text="{Binding SentDetail.RawHex, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Receive History">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Received Packets">
                        <DockPanel Margin="10">
                            <Button DockPanel.Dock="Bottom"
                                    Margin="0,10,0,0"
                                    Command="{Binding InspectSelectedReceivedPacketCommand}"
                                    Content="Inspect Selected Packet" />
                            <ListBox x:Name="ReceivedHistoryListBox"
                                     DisplayMemberPath="Summary"
                                     ItemsSource="{Binding ReceivedHistory}"
                                     MouseDoubleClick="ReceivedHistoryListBox_MouseDoubleClick"
                                     SelectedItem="{Binding SelectedReceivedHistoryEntry}" />
                        </DockPanel>
                    </GroupBox>

                    <Border Grid.Column="2"
                            Padding="16"
                            Background="White"
                            CornerRadius="10"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding ReceivedDetail.Title}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap"
                                           Text="{Binding ReceivedDetail.Summary}" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <controls:DynamicPropertyForm ItemsSource="{Binding ReceivedDetail.Properties}" />
                            </ScrollViewer>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="16,0,0,0">
                                <Button Width="100"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Left"
                                        Command="{Binding ReceivedDetail.CopyHexCommand}"
                                        Content="Copy Hex" />
                                <TextBox Padding="10"
                                         VerticalAlignment="Stretch"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         FontFamily="Consolas"
                                         IsReadOnly="True"
                                         Text="{Binding ReceivedDetail.RawHex, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Packet Registry Browser">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Registered Packets">
                        <ListBox Margin="12"
                                 FontFamily="Consolas"
                                 DisplayMemberPath="RegistryDisplay"
                                 ItemsSource="{Binding PacketTypes}"
                                 SelectedItem="{Binding SelectedPacketType}" />
                    </GroupBox>

                    <Border Grid.Column="2" Padding="16" Background="White" CornerRadius="10" BorderBrush="#D9E2EC" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding SelectedPacketType.Name}" />
                            <TextBlock Grid.Row="1" Margin="0,6,0,14" Foreground="#64748B" TextWrapping="Wrap" Text="{Binding SelectedPacketType.DetailSummary}" />
                            <Border Grid.Row="2"
                                    Padding="12"
                                    Background="#F8FAFC"
                                    CornerRadius="8"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1">
                                <Grid Grid.IsSharedSizeScope="True">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="RegistryPropertyColumn" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="RegistryTypeColumn" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock MinWidth="180"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A"
                                                   Text="Property" />
                                        <TextBlock Grid.Column="1"
                                                   MinWidth="150"
                                                   Margin="20,0,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A"
                                                   Text="Type" />
                                    </Grid>

                                    <TreeView Grid.Row="1"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Padding="0"
                                              ItemContainerStyle="{StaticResource RegistryTreeItemStyle}"
                                              ItemsSource="{Binding SelectedPacketType.Properties}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
        </DockPanel>

        <Border Background="#80000000"
                Visibility="{Binding IsHexViewerVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Border Width="720"
                        MaxHeight="520"
                        Padding="18"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="{Binding HexViewerTitle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#64748B"
                                       Text="You can copy this hex output or close this viewer." />
                        </StackPanel>

                        <TextBox Grid.Row="1"
                                 Padding="12"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 IsReadOnly="True"
                                 Text="{Binding HexViewerHex, Mode=OneWay}" />

                        <StackPanel Grid.Row="2"
                                    Margin="0,14,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Width="100"
                                    Margin="0,0,10,0"
                                    Command="{Binding CopyHexViewerCommand}"
                                    Content="Copy" />
                            <Button Width="100"
                                    Command="{Binding CloseHexViewerCommand}"
                                    Content="Close" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
