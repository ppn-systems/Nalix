<Window x:Class="Nalix.SDK.Tools.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Nalix.SDK.Tools.Views"
        Title="Nalix TCP Packet Testing Tool"
        Width="1280"
        Height="720"
        MinWidth="1280"
        MaxWidth="1280"
        MinHeight="720"
        MaxHeight="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB">
    <Grid>
        <DockPanel>
            <Border DockPanel.Dock="Top" Padding="18,14" Background="#0F172A">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Text="TCP Packet Testing Tool" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#94A3B8"
                                   Text="Reflection-driven packet builder for Nalix FrameBase packets" />
                    </StackPanel>

                    <Border Grid.Column="1" Padding="12,8" Background="#1E293B" CornerRadius="8">
                        <TextBlock Foreground="#E2E8F0" Text="{Binding StatusText}" />
                    </Border>
                </Grid>
            </Border>

            <StatusBar DockPanel.Dock="Bottom" Padding="8,4" Background="#E2E8F0">
                <StatusBarItem Content="{Binding PacketBuilder.CurrentPacketSummary}" />
            </StatusBar>

            <TabControl Margin="16">
                <TabItem Header="Packet Builder">
                    <views:PacketBuilderView DataContext="{Binding PacketBuilder}" />
                </TabItem>
                <TabItem Header="Send History">
                    <views:PacketHistoryTabView DataContext="{Binding SentHistory}" />
                </TabItem>
                <TabItem Header="Receive History">
                    <views:PacketHistoryTabView DataContext="{Binding ReceiveHistory}" />
                </TabItem>
                <TabItem Header="Packet Registry Browser">
                    <views:PacketRegistryBrowserView DataContext="{Binding PacketRegistryBrowser}" />
                </TabItem>
            </TabControl>
        </DockPanel>

        <views:HexViewerOverlay DataContext="{Binding HexViewer}" />
    </Grid>
</Window>
