<UserControl x:Class="Nalix.SDK.Tools.Views.PacketRegistryBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Nalix.SDK.Tools.Models">
    <UserControl.Resources>
        <SolidColorBrush x:Key="RegistryTreeForegroundBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="RegistryTreeTypeBrush" Color="#64748B" />
        <SolidColorBrush x:Key="RegistryTreeSelectedBrush" Color="#1E40AF" />
        <SolidColorBrush x:Key="RegistryTreeSelectedForegroundBrush" Color="#F8FAFC" />
        <Style x:Key="RegistryTreePrimaryTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource RegistryTreeForegroundBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource RegistryTreeSelectedForegroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RegistryTreeTypeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource RegistryTreePrimaryTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource RegistryTreeTypeBrush}" />
        </Style>
        <HierarchicalDataTemplate DataType="{x:Type models:PacketPropertyDefinition}"
                                  ItemsSource="{Binding Children}">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="RegistryPropertyColumn" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="RegistryTypeColumn" />
                </Grid.ColumnDefinitions>
                <TextBlock MinWidth="180"
                           FontWeight="SemiBold"
                           Style="{StaticResource RegistryTreePrimaryTextStyle}"
                           Text="{Binding DisplayName}" />
                <TextBlock Grid.Column="1"
                           MinWidth="150"
                           Margin="20,0,0,0"
                           Style="{StaticResource RegistryTreeTypeTextStyle}"
                           Text="{Binding PropertyType.Name}"
                           TextWrapping="NoWrap" />
            </Grid>
        </HierarchicalDataTemplate>
        <Style x:Key="RegistryTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource RegistryTreeForegroundBrush}" />
            <Setter Property="Padding" Value="3,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RegistryTreeSelectedBrush}" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True" />
                        <Condition Property="IsSelectionActive" Value="False" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource RegistryTreeSelectedBrush}" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="Registered Packets">
            <ListBox Margin="12"
                     FontFamily="Consolas"
                     DisplayMemberPath="RegistryDisplay"
                     ItemsSource="{Binding PacketTypes}"
                     SelectedItem="{Binding SelectedPacketType}" />
        </GroupBox>

        <Border Grid.Column="2" Padding="16" Background="White" CornerRadius="10" BorderBrush="#D9E2EC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding SelectedPacketType.Name}" />
                <TextBlock Grid.Row="1" Margin="0,6,0,14" Foreground="#64748B" TextWrapping="Wrap" Text="{Binding SelectedPacketType.DetailSummary}" />
                <Border Grid.Row="2"
                        Padding="12"
                        Background="#F8FAFC"
                        CornerRadius="8"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <Grid Grid.IsSharedSizeScope="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="RegistryPropertyColumn" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="RegistryTypeColumn" />
                            </Grid.ColumnDefinitions>
                            <TextBlock MinWidth="180"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"
                                       Text="Property" />
                            <TextBlock Grid.Column="1"
                                       MinWidth="150"
                                       Margin="20,0,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"
                                       Text="Type" />
                        </Grid>

                        <TreeView Grid.Row="1"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="0"
                                  ItemContainerStyle="{StaticResource RegistryTreeItemStyle}"
                                  ItemsSource="{Binding SelectedPacketType.Properties}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
