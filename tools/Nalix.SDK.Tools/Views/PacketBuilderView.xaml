<UserControl x:Class="Nalix.SDK.Tools.Views.PacketBuilderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Nalix.SDK.Tools.Controls">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="370" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="{Binding Source={StaticResource ToolTexts}, Path=GroupConnection}" Margin="0,0,0,12">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Source={StaticResource ToolTexts}, Path=LabelHost}" />
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,0,8" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Source={StaticResource ToolTexts}, Path=LabelPort}" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,0,8" Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Source={StaticResource ToolTexts}, Path=LabelTransport}" />
                        <ComboBox Grid.Row="2" Grid.Column="1" Margin="8,0,0,8" ItemsSource="{Binding Transports}" SelectedItem="{Binding SelectedTransport}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Source={StaticResource ToolTexts}, Path=LabelSessionToken}" />
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="8,0,0,12" Text="{Binding SessionToken, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox Grid.Row="4" Grid.Column="1" Margin="8,0,0,12" 
                                  IsChecked="{Binding AutoPingEnabled}"
                                  Content="{Binding Source={StaticResource ToolTexts}, Path=LabelAutoPing}" />

                        <UniformGrid Grid.Row="5" Grid.ColumnSpan="2" Margin="0,0,0,8" Columns="2">
                            <Button Margin="0,0,8,0" Command="{Binding ConnectCommand}" Content="{Binding Source={StaticResource ToolTexts}, Path=ButtonConnect}" />
                            <Button Command="{Binding DisconnectCommand}" Content="{Binding Source={StaticResource ToolTexts}, Path=ButtonDisconnect}" />
                        </UniformGrid>

                        <UniformGrid Grid.Row="6" Grid.ColumnSpan="2" Columns="2">
                            <Button Margin="0,0,8,0" Command="{Binding HandshakeCommand}" Content="{Binding Source={StaticResource ToolTexts}, Path=ButtonHandshake}" />
                            <Button Command="{Binding ResumeCommand}" Content="{Binding Source={StaticResource ToolTexts}, Path=ButtonResume}" />
                        </UniformGrid>
                    </Grid>
                </GroupBox>

                <GroupBox Header="{Binding Source={StaticResource ToolTexts}, Path=GroupPacketSelection}" Margin="0,0,0,12">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Source={StaticResource ToolTexts}, Path=LabelType}" />
                        <ComboBox Grid.Row="0"
                                  Grid.Column="1"
                                  Margin="8,0,0,8"
                                  DisplayMemberPath="Name"
                                  ItemsSource="{Binding PacketTypes}"
                                  SelectedItem="{Binding SelectedPacketType}" />
                        <TextBlock Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding Source={StaticResource ToolTexts}, Path=PacketSelectionHint}" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="{Binding Source={StaticResource ToolTexts}, Path=GroupActions}" Margin="0,0,0,12">
                    <StackPanel Margin="10">
                        <UniformGrid Margin="0,0,0,10" Columns="3">
                            <Button Margin="0,0,8,0" Command="{Binding ResetPacketCommand}" Content="{Binding Source={StaticResource ToolTexts}, Path=ButtonReset}" />
                            <Button Margin="0,0,8,0" Command="{Binding SerializePacketCommand}" Content="{Binding Source={StaticResource ToolTexts}, Path=ButtonSerialize}" />
                            <Button Command="{Binding SendPacketCommand}" Content="{Binding Source={StaticResource ToolTexts}, Path=ButtonSend}" />
                        </UniformGrid>

                        <UniformGrid Columns="3" Margin="0,0,0,12">
                            <RadioButton Content="Auto (Handshake)" Height="28"
                                         IsChecked="{Binding IsEncryptionDefault}" 
                                         Style="{StaticResource {x:Type ToggleButton}}" />
                            <RadioButton Content="Force Plain" Height="28"
                                         IsChecked="{Binding IsEncryptionPlain}" 
                                         Style="{StaticResource {x:Type ToggleButton}}" />
                            <RadioButton Content="Force Encrypt" Height="28"
                                         IsChecked="{Binding IsEncryptionForce}" 
                                         Style="{StaticResource {x:Type ToggleButton}}" />
                        </UniformGrid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Source={StaticResource ToolTexts}, Path=LabelRepeatCount}" />
                            <TextBox Grid.Column="1" Text="{Binding RepeatCountText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding Source={StaticResource ToolTexts}, Path=LabelRepeatDelay}" />
                            <TextBox Grid.Column="4" Text="{Binding RepeatDelayText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Button Margin="0,10,0,0"
                                Command="{Binding RepeatSendCommand}"
                                Content="{Binding Source={StaticResource ToolTexts}, Path=ButtonRepeatSend}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="{Binding Source={StaticResource ToolTexts}, Path=GroupBuilderNotes}">
                    <TextBlock Margin="10" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding ResolutionText}" />
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="2"
                Padding="16"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="10"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding CurrentPacketTitle}" />
                    <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Text="{Binding CurrentPacketSummary}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <controls:DynamicPropertyForm ItemsSource="{Binding CurrentProperties}" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
