<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B1220" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#111827" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#162033" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#020617" />
    <SolidColorBrush x:Key="HeaderCardBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E5EEF8" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A7B4C7" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="InversePrimaryTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InverseSecondaryTextBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="BorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#475569" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#E5EEF8" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#475569" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="SelectionTextBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#111827" />
    <SolidColorBrush x:Key="OverlayBrush" Color="#A0000000" />
    <SolidColorBrush x:Key="HexEditorSurfaceBrush" Color="#020617" />
    <SolidColorBrush x:Key="HexEditorBorderBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="HexEditorTextBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="HexEditorInputBackgroundBrush" Color="#020617" />
    <SolidColorBrush x:Key="HexEditorInputForegroundBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="HexEditorInputBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#F87171" />

    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    </Style>

    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    </Style>

    <Style TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource ControlForegroundBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBrush}" />
        <Setter Property="SelectionTextBrush" Value="{DynamicResource SelectionTextBrush}" />
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    </Style>

    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}" />
                <Setter Property="Background" Value="{DynamicResource SelectionBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type TreeView}">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    </Style>

    <Style TargetType="{x:Type StatusBar}">
        <Setter Property="Background" Value="{DynamicResource StatusBarBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
    </Style>
</ResourceDictionary>
