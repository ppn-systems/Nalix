<UserControl x:Class="Nalix.SDK.Tools.Controls.HexEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="170">
    <Border Padding="10"
            Background="#0F172A"
            CornerRadius="8"
            BorderBrush="#1E293B"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False">
                <TextBlock x:Name="ByteCountTextBlock"
                           Foreground="#CBD5E1"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           Text="0 bytes" />

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Margin="0,0,8,0"
                            Padding="10,4"
                            Click="ImportButton_Click"
                            Content="Import .bin" />
                    <Button Padding="10,4"
                            Click="ExportButton_Click"
                            Content="Export .bin" />
                </StackPanel>
            </DockPanel>

            <TextBox x:Name="HexTextBox"
                     Grid.Row="1"
                     Margin="0,10,0,8"
                     Padding="10"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     Foreground="#F8FAFC"
                     Background="#020617"
                     BorderBrush="#334155"
                     BorderThickness="1"
                     TextChanged="HexTextBox_TextChanged"
                     LostKeyboardFocus="HexTextBox_LostKeyboardFocus" />

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="2"
                       Foreground="#94A3B8"
                       FontSize="11"
                       Text="Hex input accepts spaces and line breaks." />
        </Grid>
    </Border>
</UserControl>
