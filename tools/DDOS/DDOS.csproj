<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<UseWindowsForms>true</UseWindowsForms>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
	  <Reference Include="Nalix.SDK">
	    <HintPath>..\..\build\bin\Release\net10.0\Nalix.SDK.dll</HintPath>
	  </Reference>
		<Reference Include="Nalix.Common">
			<HintPath>..\..\build\bin\Release\net10.0\Nalix.Common.dll</HintPath>
		</Reference>
		<Reference Include="Nalix.Shared">
			<HintPath>..\..\build\bin\Release\net10.0\Nalix.Shared.dll</HintPath>
		</Reference>
		<Reference Include="Nalix.Framework">
			<HintPath>..\..\build\bin\Release\net10.0\Nalix.Framework.dll</HintPath>
		</Reference>
	</ItemGroup>

</Project>